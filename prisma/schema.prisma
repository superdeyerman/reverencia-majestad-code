generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  PROFESSIONAL
  CLIENT
}

enum Segment {
  NEW
  RECURRENT
  VIP
}

enum ServiceCategory {
  BEAUTY
  WELLNESS
  SKINCARE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum BookingModality {
  HOME
  HOTEL
}

enum HairLength {
  SHORT
  MEDIUM
  LONG
  XL
}

enum HairDensity {
  LIGHT
  NORMAL
  ABUNDANT
}

enum ProfessionalKind {
  STYLIST
  THERAPIST
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_REMINDER
  REVIEW_REQUEST
  REBOOKING_OFFER
}

model User {
  id            String               @id @default(cuid())
  email         String               @unique
  passwordHash  String?
  name          String
  phone         String
  role          Role                 @default(CLIENT)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  customer      CustomerProfile?
  professional  ProfessionalProfile?
  bookings      Booking[]            @relation("CustomerBookings")
  assignedJobs  Booking[]            @relation("AssignedProfessional")
  notesAuthored InternalNote[]
}

model CustomerProfile {
  id                 String         @id @default(cuid())
  userId             String         @unique
  segment            Segment        @default(NEW)
  visitCount         Int            @default(0)
  totalSpent         Int            @default(0)
  lastVisitAt        DateTime?
  preferences        String?
  customerSince      DateTime       @default(now())
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes              InternalNote[]
}

model ProfessionalProfile {
  id               String                @id @default(cuid())
  userId           String                @unique
  kind             ProfessionalKind
  bio              String?
  specialties      String[]
  commissionRate   Float                 @default(0.35)
  isActive         Boolean               @default(true)
  city             String                @default("Santiago")
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  services         ProfessionalService[]
}

model Service {
  id                   String                @id @default(cuid())
  slug                 String                @unique
  name                 String
  category             ServiceCategory
  description          String
  basePrice            Int
  durationMinutes      Int
  supportsHome         Boolean               @default(true)
  supportsHotel        Boolean               @default(true)
  supportsHairMetrics  Boolean               @default(false)
  isFeatured           Boolean               @default(false)
  isActive             Boolean               @default(true)
  bookings             Booking[]
  professionals        ProfessionalService[]
}

model ProfessionalService {
  id             String               @id @default(cuid())
  professionalId String
  serviceId      String
  professional   ProfessionalProfile  @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service        Service              @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([professionalId, serviceId])
}

model HotelPartner {
  id                String      @id @default(cuid())
  name              String
  contactName       String
  email             String      @unique
  phone             String
  address           String
  district          String
  commissionRate    Float       @default(0.12)
  notes             String?
  active            Boolean     @default(true)
  createdAt         DateTime    @default(now())
  bookings          Booking[]
}

model HotelLead {
  id                String      @id @default(cuid())
  hotelName         String
  contactName       String
  email             String
  phone             String
  rooms             Int
  averageTicket     Int
  notes             String?
  createdAt         DateTime    @default(now())
}

model Booking {
  id                String           @id @default(cuid())
  code              String           @unique
  customerId        String
  professionalId    String?
  serviceId         String
  hotelPartnerId    String?
  status            BookingStatus    @default(PENDING)
  modality          BookingModality
  appointmentAt     DateTime
  address           String
  district          String
  latitude          Float?
  longitude         Float?
  hotelName         String?
  roomNumber        String?
  hairLength        HairLength?
  hairDensity       HairDensity?
  notes             String?
  subtotal          Int
  distanceFee       Int              @default(0)
  depositAmount     Int              @default(5000)
  totalAmount       Int
  isDepositPaid     Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  customer          User             @relation("CustomerBookings", fields: [customerId], references: [id], onDelete: Cascade)
  professional      User?            @relation("AssignedProfessional", fields: [professionalId], references: [id])
  service           Service          @relation(fields: [serviceId], references: [id])
  hotelPartner      HotelPartner?    @relation(fields: [hotelPartnerId], references: [id])
  notifications     NotificationLog[]
}

model InternalNote {
  id          String           @id @default(cuid())
  customerId  String
  authorId    String
  body        String
  createdAt   DateTime         @default(now())
  customer    CustomerProfile  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  author      User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model NotificationLog {
  id            String               @id @default(cuid())
  bookingId     String
  channel       NotificationChannel
  type          NotificationType
  scheduledFor  DateTime
  sentAt        DateTime?
  status        String               @default("queued")
  payload       Json?
  booking       Booking              @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}
