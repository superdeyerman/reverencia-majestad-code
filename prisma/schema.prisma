generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CUSTOMER
  PROFESSIONAL
  HOTEL_MANAGER
  STAFF
  CLIENT
}

enum Segment {
  NEW
  RECURRENT
  VIP
}

enum ServiceCategory {
  BEAUTY
  WELLNESS
  SKINCARE
  NAILS
  MAKEUP
  BODY_TREATMENTS
  HAIR
  COLOR
  EXTENSIONS
  HOTEL
}

enum BookingStatus {
  PENDING
  PENDING_PAYMENT
  PAYMENT_PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  PAYMENT_FAILED
  RESCHEDULED
  ARCHIVED
}

enum BookingModality {
  STUDIO
  HOME
  HOTEL
  PRIVATE_STUDIO
}

enum HairLength {
  SHORT
  MEDIUM
  LONG
  EXTRA_LONG
  XL
}

enum HairDensity {
  THIN
  LIGHT
  NORMAL
  ABUNDANT
  VERY_ABUNDANT
}

enum ProfessionalKind {
  STYLIST
  THERAPIST
}

enum ProfLevel {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum LoyaltyTier {
  STANDARD
  SILVER
  GOLD
  VIP
  PLATINUM
}

enum HotelStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
  IN_APP
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_REMINDER
  REVIEW_REQUEST
  REBOOKING_OFFER
  PAYMENT_UPDATE
  GENERAL
}

enum PaymentProvider {
  MERCADO_PAGO
}

enum PaymentStatus {
  CREATED
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  REFUNDED
  CHARGED_BACK
  FAILED
  IN_PROCESS
}

enum PaymentType {
  DEPOSIT
  FULL
  BALANCE
  REFUND
  ADJUSTMENT
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?
  passwordHash String?
  role         Role     @default(CUSTOMER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs     AuditLog[]
  customer      CustomerProfile?
  notesAuthored InternalNote[]
  notifications Notification[]
  professional  ProfessionalProfile?

  bookings     Booking[] @relation("Booking_customerIdToUser")
  assignedJobs Booking[] @relation("Booking_professionalIdToUser")
}

model Service {
  id                  String          @id @default(cuid())
  slug                String          @unique
  name                String
  category            ServiceCategory
  description         String
  basePrice           Int
  durationMinutes     Int
  imageUrl            String?
  supportsHome        Boolean         @default(true)
  supportsHotel       Boolean         @default(true)
  supportsHairMetrics Boolean         @default(false)
  isActive            Boolean         @default(true)
  isFeatured          Boolean         @default(false)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  bookings      Booking[]
  bookingItems  BookingService[]
  professionals ProfessionalService[]

  @@index([category])
  @@index([isActive])
  @@index([isFeatured])
}

model Booking {
  id                 String        @id @default(cuid())
  code               String        @unique
  customerId         String
  professionalId     String?
  serviceId          String
  hotelPartnerId     String?
  status             BookingStatus @default(PENDING_PAYMENT)
  modality           BookingModality
  appointmentAt      DateTime

  address      String?
  district     String?
  latitude     Float?
  longitude    Float?
  hotelName    String?
  roomNumber   String?
  hairLength   HairLength?
  hairDensity  HairDensity?
  notes        String?

  subtotal           Int
  surchargeLength    Int @default(0)
  surchargeAbundance Int @default(0)
  surchargeDomicile  Int @default(0)
  distanceFee        Int @default(0)
  totalAmount        Int
  depositAmount      Int
  balanceAmount      Int @default(0)
  paidAmountTotal    Int @default(0)

  isDepositPaid Boolean   @default(false)
  paidAt        DateTime?
  reminderSentAt DateTime?

  paymentProvider   PaymentProvider?
  externalReference String? @unique
  lastPaymentId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  city         String?
  commune      String?
  discount     Int     @default(0)
  region       String?
  street       String?
  streetNumber String?
  unit         String?

  customer      User          @relation("Booking_customerIdToUser", fields: [customerId], references: [id], onDelete: Cascade)
  professional  User?         @relation("Booking_professionalIdToUser", fields: [professionalId], references: [id])
  service       Service       @relation(fields: [serviceId], references: [id])
  hotelPartner  HotelPartner? @relation(fields: [hotelPartnerId], references: [id])
  lastPayment   Payment?      @relation("Booking_lastPaymentIdToPayment", fields: [lastPaymentId], references: [id])

  items         BookingService[]
  notifications NotificationLog[]
  payments      Payment[] @relation("BookingPayments")

  @@index([appointmentAt])
  @@index([createdAt])
  @@index([customerId])
  @@index([hotelPartnerId])
  @@index([modality])
  @@index([professionalId])
  @@index([serviceId])
  @@index([status])
}

model BookingService {
  id               String   @id @default(cuid())
  bookingId        String
  serviceId        String
  nameSnapshot     String
  priceSnapshot    Int
  durationSnapshot Int
  createdAt        DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])

  @@unique([bookingId, serviceId])
  @@index([bookingId])
  @@index([serviceId])
}

model Payment {
  id                       String          @id @default(cuid())
  bookingId                String
  provider                 PaymentProvider @default(MERCADO_PAGO)
  type                     PaymentType     @default(DEPOSIT)
  status                   PaymentStatus   @default(CREATED)
  externalReference        String
  providerPaymentId        String?         @unique
  providerPreferenceId     String?
  providerMerchantOrderId  String?
  currency                 String          @default("CLP")
  amount                   Int
  netAmount                Int?
  feeAmount                Int?
  paidAt                   DateTime?
  expiresAt                DateTime?
  statusDetail             String?
  rejectionReason          String?
  description              String?
  payerEmail               String?
  payerFirstName           String?
  payerLastName            String?
  payerIdentificationType  String?
  payerIdentificationNumber String?
  rawPayload               Json?
  rawCreatePayload         Json?
  rawWebhookPayload        Json?
  rawProviderPayment       Json?
  idempotencyKey           String?
  processedAt              DateTime?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  booking            Booking        @relation("BookingPayments", fields: [bookingId], references: [id], onDelete: Cascade)
  bookingLastPayment Booking[]      @relation("Booking_lastPaymentIdToPayment")
  events             PaymentEvent[]

  @@unique([provider, externalReference, type])
  @@index([bookingId])
  @@index([provider, status])
  @@index([externalReference])
}

model CustomerProfile {
  id            String      @id @default(cuid())
  userId        String      @unique
  phone         String?
  totalSpent    Int         @default(0)
  visits        Int         @default(0)
  visitCount    Int         @default(0)
  loyaltyTier   LoyaltyTier @default(STANDARD)
  segment       Segment     @default(NEW)
  lastVisitAt   DateTime?
  notes         String?
  preferences   Json?
  customerSince DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  notesRelation InternalNote[] @relation("CustomerNotes")
}

model ProfessionalProfile {
  id                   String           @id @default(cuid())
  userId               String           @unique
  kind                 ProfessionalKind
  level                ProfLevel        @default(BRONZE)
  specialties          String[]
  bio                  String?
  photoUrl             String?
  rating               Float            @default(0)
  reviews              Int              @default(0)
  commissionRate       Float            @default(0.20)
  commissionPercentage Float            @default(20)
  completedBookings    Int              @default(0)
  totalEarnings        Int              @default(0)
  city                 String           @default("Santiago")
  isActive             Boolean          @default(true)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  availability Availability[]
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  services     ProfessionalService[]

  @@index([city])
  @@index([isActive])
  @@index([level])
}

model ProfessionalService {
  id             String @id @default(cuid())
  professionalId String
  serviceId      String

  professional ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service      Service             @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([professionalId, serviceId])
  @@index([professionalId])
  @@index([serviceId])
}

model Availability {
  id             String  @id @default(cuid())
  professionalId String
  weekday        Int
  startTime      String
  endTime        String
  isAvailable    Boolean @default(true)

  professional ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId, weekday])
}

model HotelPartner {
  id             String      @id @default(cuid())
  name           String
  contactName    String
  email          String      @unique
  phone          String
  address        String?
  district       String?
  commissionRate Float       @default(0.12)
  status         HotelStatus @default(ACTIVE)
  notes          String?
  active         Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  bookings Booking[]

  @@index([status])
  @@index([active])
}

model HotelLead {
  id            String     @id @default(cuid())
  hotelName     String
  contactName   String
  email         String
  phone         String?
  rooms         Int?
  averageTicket Int?
  message       String?
  notes         String?
  status        LeadStatus @default(NEW)
  createdAt     DateTime   @default(now())

  @@index([status])
  @@index([createdAt])
}

model Testimonial {
  id         String   @id @default(cuid())
  clientName String
  text       String
  rating     Int
  photoUrl   String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([isActive])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  channel   NotificationChannel @default(IN_APP)
  type      NotificationType
  title     String
  message   String
  readAt    DateTime?
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([readAt])
  @@index([createdAt])
}

model NotificationLog {
  id           String              @id @default(cuid())
  bookingId    String
  channel      NotificationChannel
  type         NotificationType
  scheduledFor DateTime
  sentAt       DateTime?
  status       String              @default("queued")
  payload      Json?

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([scheduledFor])
  @@index([status])
}

model PaymentEvent {
  id                String          @id @default(cuid())
  paymentId         String?
  provider          PaymentProvider
  eventType         String?
  action            String?
  topic             String?
  resourceId        String?
  externalReference String?
  notificationId    String?
  webhookSignature  String?
  payload           Json
  isProcessed       Boolean         @default(false)
  processedAt       DateTime?
  errorMessage      String?
  createdAt         DateTime        @default(now())

  payment Payment? @relation(fields: [paymentId], references: [id])

  @@unique([provider, notificationId])
  @@index([paymentId])
  @@index([provider, resourceId])
  @@index([externalReference])
  @@index([isProcessed])
}

model InternalNote {
  id         String   @id @default(cuid())
  customerId String
  authorId   String
  body       String
  createdAt  DateTime @default(now())

  author   User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  customer CustomerProfile @relation("CustomerNotes", fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([authorId])
}