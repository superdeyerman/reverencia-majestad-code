generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  CUSTOMER
  PROFESSIONAL
  HOTEL_MANAGER
  STAFF
  CLIENT
}

enum Segment {
  NEW
  RECURRENT
  VIP
}

enum ServiceCategory {
  BEAUTY
  WELLNESS
  SKINCARE
  NAILS
  MAKEUP
  BODY_TREATMENTS
}

enum BookingStatus {
  PENDING
  PENDING_PAYMENT
  PAYMENT_PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  PAYMENT_FAILED
  RESCHEDULED
  ARCHIVED
}

enum BookingModality {
  STUDIO
  HOME
  HOTEL
  PRIVATE_STUDIO
}

enum HairLength {
  SHORT
  MEDIUM
  LONG
  EXTRA_LONG
  XL
}

enum HairDensity {
  THIN
  LIGHT
  NORMAL
  ABUNDANT
  VERY_ABUNDANT
}

enum ProfessionalKind {
  STYLIST
  THERAPIST
}

enum ProfLevel {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum LoyaltyTier {
  STANDARD
  SILVER
  GOLD
  VIP
  PLATINUM
}

enum HotelStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
  IN_APP
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_REMINDER
  REVIEW_REQUEST
  REBOOKING_OFFER
  PAYMENT_UPDATE
  GENERAL
}

enum PaymentProvider {
  MERCADO_PAGO
}

enum PaymentStatus {
  CREATED
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  REFUNDED
  CHARGED_BACK
  FAILED
  IN_PROCESS
}

enum PaymentType {
  DEPOSIT
  FULL
  BALANCE
  REFUND
  ADJUSTMENT
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?
  passwordHash String?
  role         Role     @default(CUSTOMER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  customer      CustomerProfile?
  professional  ProfessionalProfile?
  notifications Notification[]
  auditLogs     AuditLog[]

  bookings      Booking[]      @relation("CustomerBookings")
  assignedJobs  Booking[]      @relation("AssignedProfessional")
  notesAuthored InternalNote[]
}

model Service {
  id                  String          @id @default(cuid())
  slug                String          @unique
  name                String
  category            ServiceCategory
  description         String
  basePrice           Int
  durationMinutes     Int
  imageUrl            String?
  supportsHome        Boolean         @default(true)
  supportsHotel       Boolean         @default(true)
  supportsHairMetrics Boolean         @default(false)
  isActive            Boolean         @default(true)
  isFeatured          Boolean         @default(false)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @default(now()) @updatedAt

  bookings      Booking[]
  professionals ProfessionalService[]
}

model Booking {
  id                 String           @id @default(cuid())
  code               String           @unique
  customerId         String
  professionalId     String?
  serviceId          String
  hotelPartnerId     String?
  status             BookingStatus    @default(PENDING_PAYMENT)
  modality           BookingModality
  appointmentAt      DateTime
  address            String?
  district           String?
  latitude           Float?
  longitude          Float?
  hotelName          String?
  roomNumber         String?
  hairLength         HairLength?
  hairDensity        HairDensity?
  notes              String?
  subtotal           Int
  surchargeLength    Int              @default(0)
  surchargeAbundance Int              @default(0)
  surchargeDomicile  Int              @default(0)
  distanceFee        Int              @default(0)
  totalAmount        Int
  depositAmount      Int
  balanceAmount      Int              @default(0)
  paidAmountTotal    Int              @default(0)
  isDepositPaid      Boolean          @default(false)
  paidAt             DateTime?
  reminderSentAt     DateTime?
  paymentProvider    PaymentProvider?
  externalReference  String?          @unique
  lastPaymentId      String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @default(now()) @updatedAt

  customer     User          @relation("CustomerBookings", fields: [customerId], references: [id], onDelete: Cascade)
  professional User?         @relation("AssignedProfessional", fields: [professionalId], references: [id], onDelete: SetNull)
  service      Service       @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  hotelPartner HotelPartner? @relation(fields: [hotelPartnerId], references: [id], onDelete: SetNull)
  lastPayment  Payment?      @relation("LastBookingPayment", fields: [lastPaymentId], references: [id], onDelete: SetNull)

  payments      Payment[]         @relation("BookingPayments")
  notifications NotificationLog[]

  @@index([customerId])
  @@index([professionalId])
  @@index([serviceId])
  @@index([hotelPartnerId])
  @@index([status])
  @@index([appointmentAt])
}

model Payment {
  id                        String          @id @default(cuid())
  bookingId                 String
  provider                  PaymentProvider @default(MERCADO_PAGO)
  type                      PaymentType     @default(DEPOSIT)
  status                    PaymentStatus   @default(CREATED)
  externalReference         String
  providerPaymentId         String?         @unique
  providerPreferenceId      String?
  providerMerchantOrderId   String?
  currency                  String          @default("CLP")
  amount                    Int
  netAmount                 Int?
  feeAmount                 Int?
  paidAt                    DateTime?
  expiresAt                 DateTime?
  statusDetail              String?
  rejectionReason           String?
  description               String?
  payerEmail                String?
  payerFirstName            String?
  payerLastName             String?
  payerIdentificationType   String?
  payerIdentificationNumber String?
  rawPayload                Json?
  rawCreatePayload          Json?
  rawWebhookPayload         Json?
  rawProviderPayment        Json?
  idempotencyKey            String?
  processedAt               DateTime?
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @default(now()) @updatedAt

  booking            Booking        @relation("BookingPayments", fields: [bookingId], references: [id], onDelete: Cascade)
  bookingLastPayment Booking[]      @relation("LastBookingPayment")
  events             PaymentEvent[]

  @@unique([provider, externalReference, type])
  @@index([bookingId])
  @@index([provider, status])
}

model CustomerProfile {
  id            String      @id @default(cuid())
  userId        String      @unique
  phone         String?
  totalSpent    Int         @default(0)
  visits        Int         @default(0)
  visitCount    Int         @default(0)
  loyaltyTier   LoyaltyTier @default(STANDARD)
  segment       Segment     @default(NEW)
  lastVisitAt   DateTime?
  notes         String?
  preferences   Json?
  customerSince DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @default(now()) @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  notesRelation InternalNote[] @relation("CustomerNotes")
}

model ProfessionalProfile {
  id                   String           @id @default(cuid())
  userId               String           @unique
  kind                 ProfessionalKind
  level                ProfLevel        @default(BRONZE)
  specialties          String[]
  bio                  String?
  photoUrl             String?
  rating               Float            @default(0)
  reviews              Int              @default(0)
  commissionRate       Float            @default(0.20)
  commissionPercentage Float            @default(20)
  completedBookings    Int              @default(0)
  totalEarnings        Int              @default(0)
  city                 String           @default("Santiago")
  isActive             Boolean          @default(true)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @default(now()) @updatedAt

  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  availability Availability[]
  services     ProfessionalService[]
}

model ProfessionalService {
  id             String @id @default(cuid())
  professionalId String
  serviceId      String

  professional ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service      Service             @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([professionalId, serviceId])
}

model Availability {
  id             String  @id @default(cuid())
  professionalId String
  weekday        Int
  startTime      String
  endTime        String
  isAvailable    Boolean @default(true)

  professional ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId, weekday])
}

model HotelPartner {
  id             String      @id @default(cuid())
  name           String
  contactName    String
  email          String      @unique
  phone          String
  address        String?
  district       String?
  commissionRate Float       @default(0.12)
  status         HotelStatus @default(ACTIVE)
  notes          String?
  active         Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @default(now()) @updatedAt

  bookings Booking[]
}

model HotelLead {
  id            String     @id @default(cuid())
  hotelName     String
  contactName   String
  email         String
  phone         String?
  rooms         Int?
  averageTicket Int?
  message       String?
  notes         String?
  status        LeadStatus @default(NEW)
  createdAt     DateTime   @default(now())
}

model Testimonial {
  id         String   @id @default(cuid())
  clientName String
  text       String
  rating     Int
  photoUrl   String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entity, entityId])
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  channel   NotificationChannel @default(IN_APP)
  type      NotificationType
  title     String
  message   String
  readAt    DateTime?
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationLog {
  id           String              @id @default(cuid())
  bookingId    String
  channel      NotificationChannel
  type         NotificationType
  scheduledFor DateTime
  sentAt       DateTime?
  status       String              @default("queued")
  payload      Json?

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([scheduledFor])
}

model PaymentEvent {
  id                String          @id @default(cuid())
  paymentId         String?
  provider          PaymentProvider
  eventType         String?
  action            String?
  topic             String?
  resourceId        String?
  externalReference String?
  notificationId    String?
  webhookSignature  String?
  payload           Json
  isProcessed       Boolean         @default(false)
  processedAt       DateTime?
  errorMessage      String?
  createdAt         DateTime        @default(now())

  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@unique([provider, notificationId])
  @@index([paymentId])
  @@index([provider, resourceId])
}

model InternalNote {
  id         String   @id @default(cuid())
  customerId String
  authorId   String
  body       String
  createdAt  DateTime @default(now())

  customer CustomerProfile @relation("CustomerNotes", fields: [customerId], references: [id], onDelete: Cascade)
  author   User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
}
